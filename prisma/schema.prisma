// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  lastName    String
  cedula      String?  @unique
  phone       String?
  country     String?
  city        String?
  profession  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  surveyResponses     SurveyResponse[]
  campaignSignatures  CampaignSignature[]
  returnRegistrations ReturnRegistration[]
  connectionPosts     ConnectionPost[]
  predictorSettings   PredictorSettings?
  marketPredictions   MarketPrediction[]
  betOrders           BetOrder[]

  @@map("users")
}

model Survey {
  id          String     @id @default(cuid())
  title       String
  description String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  questions  Question[]
  responses  SurveyResponse[]

  @@map("surveys")
}

model Question {
  id        String   @id @default(cuid())
  surveyId  String
  text      String
  type      String   // 'text', 'multiple', 'single', 'rating'
  options   String?  // JSON string for options

  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model SurveyResponse {
  id        String   @id @default(cuid())
  surveyId  String
  userId    String
  answers   String   // JSON string of answers
  createdAt DateTime @default(now())

  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

model Campaign {
  id             String   @id @default(cuid())
  title          String
  description    String
  country        String
  ministry       String
  letterTemplate String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  signatures     CampaignSignature[]

  @@map("campaigns")
}

model CampaignSignature {
  id          String   @id @default(cuid())
  campaignId  String
  userId      String
  createdAt   DateTime @default(now())

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@map("campaign_signatures")
}

model ReturnRegistration {
  id          String   @id @default(cuid())
  userId      String
  destination String
  timeline    String
  skills      String
  needs       String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("return_registrations")
}

model ConnectionPost {
  id        String   @id @default(cuid())
  userId    String
  category  String   // 'knowledge', 'remesas', 'networking'
  title     String
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("connection_posts")
}

// ---- Predictor / Betting Tool ----

model PredictorSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  mode           String   @default("paper")   // "paper" | "real"
  paperBalance   Float    @default(1000.0)
  maxBetPct          Float    @default(5.0)        // max % of balance per bet
  autoBet            Boolean  @default(false)
  minConfidence      Float    @default(0.65)       // min AI confidence to auto-bet
  aiCostPerPrediction Float   @default(0.10)       // estimated USD cost per Claude prediction
  polyApiKey         String?
  polyApiSecret  String?
  polyPassphrase String?
  polyAddress    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("predictor_settings")
}

model MarketPrediction {
  id                 String   @id @default(cuid())
  userId             String
  marketId           String
  marketSlug         String
  question           String
  category           String   @default("other")
  outcomes           String   // JSON: ["Yes", "No"]
  currentOdds        String   // JSON: {"Yes": 0.65, "No": 0.35}
  prediction         String   // predicted winning outcome
  confidence         Float    // 0.0 - 1.0
  reasoning          String
  suggestedBetSize   Float
  status             String   @default("pending") // pending | won | lost | void
  resolvedOutcome    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  betOrders          BetOrder[]

  @@map("market_predictions")
}

model BetOrder {
  id           String   @id @default(cuid())
  userId       String
  predictionId String?
  marketId     String
  marketSlug   String
  question     String
  outcome      String   // which outcome was bet on
  amount       Float    // USDC amount wagered
  price        Float    // price at bet time (0-1), implied probability
  potentialWin Float    // amount to receive if win
  mode         String   // "paper" | "real"
  status       String   @default("open") // open | won | lost | void | cancelled
  externalId   String?  // Polymarket order ID (for real bets)
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction   MarketPrediction? @relation(fields: [predictionId], references: [id])

  @@map("bet_orders")
}
